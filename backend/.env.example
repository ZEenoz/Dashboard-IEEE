# --- Database ---
DATABASE_URL=postgres://user:password@host:port/database

# --- MQTT (TTN/TTI) ---
TTI_HOST=ieeew2025.as1.cloud.thethings.industries
TTI_APP_ID=ieee2025
TTI_TENANT_ID=ieeew2025
TTI_API_KEY=NNSXS.YOUR_ACTUAL_KEY_HERE

# --- MQTT (ChirpStack) ---
CHIRPSTACK_MQTT_URL=mqtt://your-chirpstack-ip:1883
CHIRPSTACK_MQTT_USER=
CHIRPSTACK_MQTT_PASS=
CHIRPSTACK_APP_ID=your-app-uuid

# --- Google Sheets (Optional) ---
GOOGLE_SHEET_ID=your-spreadsheet-id
GOOGLE_SERVICE_ACCOUNT='{"type": "service_account", ...}'

# --- System ---
PORT=4000
NODE_ENV=production
